{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Farmer": {
    "Paths": {
      "Root": "D:\\work\\planning-runtime",
      "Data": "D:\\work\\planning-runtime\\data",
      "Runs": "D:\\work\\planning-runtime\\runs",
      "Inbox": "D:\\work\\planning-runtime\\inbox",
      "Outbox": "D:\\work\\planning-runtime\\outbox",
      "Qa": "D:\\work\\planning-runtime\\qa"
    },
    "Telemetry": {
      "ServiceName": "Farmer",
      "OtlpEndpoint": "http://localhost:18889",
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true
    },
    "MaxRetries": 2,
    "SshKeyPath": "id_ed25519",
    "SshCommandTimeoutSeconds": 30,
    "SshDispatchTimeoutMinutes": 30,
    "SshfsCacheLagMs": 500,
    "ProgressPollIntervalMs": 2000,
    "Vms": [
      {
        "Name": "claudefarm2",
        "SshHost": "claudefarm2",
        "SshUser": "claude",
        "MappedDriveLetter": "O",
        "RemoteProjectPath": "/home/claude/projects"
      }
    ]
  }
}
