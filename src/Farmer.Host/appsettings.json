{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Farmer": {
    "Paths": {
      "Root": "D:\\work\\planning-runtime",
      "Data": "D:\\work\\planning-runtime\\data",
      "Runs": "D:\\work\\planning-runtime\\runs",
      "Inbox": "D:\\work\\planning-runtime\\inbox",
      "Outbox": "D:\\work\\planning-runtime\\outbox",
      "Qa": "D:\\work\\planning-runtime\\qa"
    },
    "Telemetry": {
      "ServiceName": "Farmer",
      "OtlpEndpoint": "http://localhost:18889",
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true
    },
    "OpenAI": {
      "Endpoint": "https://farmer-openai-dev.openai.azure.com/",
      "DeploymentName": "gpt-4.1-mini",
      "MaxOutputTokens": 2048,
      "TimeoutSeconds": 60
    },
    "Retrospective": {
      "FailureBehavior": "AutoPass",
      "MaxAgentCallRetries": 2,
      "MaxChangedFiles": 10,
      "MaxFileBytes": 8192,
      "ExecutionLogTailLines": 200
    },
    "MaxRetries": 2,
    "SshKeyPath": "id_ed25519",
    "SshCommandTimeoutSeconds": 30,
    "SshDispatchTimeoutMinutes": 30,
    "SshfsCacheLagMs": 500,
    "ProgressPollIntervalMs": 2000,
    "Vms": [
      {
        "Name": "vm-golden",
        "SshHost": "vm-golden",
        "SshUser": "claude",
        "MappedDriveLetter": "K",
        "RemoteProjectPath": "/home/claude/projects"
      }
    ]
  }
}
